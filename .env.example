# ================================
# EXEMPLO DE CONFIGURAÇÃO LOCAL
# ================================
# Copie este arquivo para .env e preencha os valores

# ================================
# DJANGO
# ================================
# Modo de debug (True para desenvolvimento, False para produção)
DEBUG=True

# Chave secreta (mude isso em produção!)
SECRET_KEY=sua-chave-segura-super-secreta-aqui-minimo-50-caracteres

# Hosts permitidos
ALLOWED_HOSTS=127.0.0.1,localhost

# ================================
# BANCO DE DADOS
# ================================
# Use o padrão SQLite para desenvolvimento local
# DATABASE_URL=sqlite:///db.sqlite3

# Ou configure PostgreSQL se preferir
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/enertech

# ================================
# SEGURANÇA
# ================================
# URLs confiáveis para CSRF (HTTPS)
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ================================
# RENDER (Produção)
# ================================
# Descomente e configure quando deployar no Render
# DEBUG=False
# SECRET_KEY=sua-super-chave-segura-em-producao
# ALLOWED_HOSTS=seu-app-name.onrender.com
# CSRF_TRUSTED_ORIGINS=https://seu-app-name.onrender.com
# DATABASE_URL=postgresql://usuario:senha@seu-host:5432/enertech
